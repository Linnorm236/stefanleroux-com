---
import BlockHead from "../blocks/BlockHead.astro";

const { pathname } = Astro.url;

const { title, description, image = "favicon.svg" } = Astro.props;
---

<!doctype html>
<html lang="en">
	<BlockHead title={title} description={description} image={image} />
	<body>
		<input type="checkbox" id="menu" />
		<nav>
			<div class="sticky">
				<div class="links">
					<div class="profile">
						<img src="" alt="profile" />
					</div>
					<ul role="list">
						<li><a aria-current={pathname === "/" ? "page" : "false"} href="/">Home</a></li>
						<li><a aria-current={pathname === "/about/" ? "page" : "false"} href="/about/">About</a></li>
						<li><a aria-current={pathname === "/blogs/" ? "page" : "false"} href="/blogs/">Blogs</a></li>
					</ul>
				</div>
				<div class="hamburger">
					<label for="menu">Menu</label>
				</div>
			</div>
		</nav>
		<main>
			<slot />
		</main>
		<footer>test</footer>
	</body>
</html>

<style>
	body {
		--timing: 0.5s;
		--easing: cubic-bezier(0.8, -0.4, 0.5, 1);
		min-block-size: 100svh;
		display: grid;
		grid:
			"nav head" auto
			"nav main" 1fr
			"nav foo" auto / minmax(0, 250px) minmax(0, 1fr);

		nav {
			grid-area: nav;
		}

		main {
			grid-area: main;
		}

		footer {
			grid-area: foo;
		}

		& > input {
			position: fixed;
			width: 0;
			height: 0;
			opacity: 0;
		}

		@media (width <= 800px) {
			& {
				overflow-x: clip;
				grid-template-columns: minmax(0, 0) minmax(0, 1fr);
				transition: grid-template-columns var(--timing) var(--easing);

				main,
				footer {
					transition: filter var(--timing) var(--easing);
				}
			}

			&:has(> input:checked) {
				grid-template-columns: minmax(0, 250px) minmax(0, 1fr);
				transition-timing-function: ease-in-out;
				transition-duration: 0.2s;

				main,
				footer {
					filter: blur(5px) saturate(50%);
					transition-timing-function: ease-in-out;
					transition-duration: 0.2s;
				}
			}

			main {
				min-width: 100vw;
			}
		}
	}

	main {
		> * {
			width: min(1200px, 100%);
			margin-inline: auto;
		}
	}

	nav {
		background: var(--c-blu);
		border-right: solid 3px var(--c-yel);
		position: relative;
		z-index: 1;

		.hamburger {
			display: none;
			position: absolute;
			inset: auto 0 0 auto;
			translate: 100% 0%;
			aspect-ratio: 1;
			width: 100px;
			z-index: 1;

			label {
				display: block;
				block-size: 100%;
				inline-size: 100%;
				background: var(--c-blu);
				border: solid 3px var(--c-yel);
				border-left: unset;
				border-bottom: unset;

				&::before {
					display: none;
					content: "";
					position: fixed;
					inset: auto auto 0 0;
					inline-size: 100vw;
					block-size: 100vh;
					z-index: -1;
				}
			}

			@media (width <= 800px) {
				& {
					display: block;
				}
			}

			body:has(input:checked) & label::before {
				display: block;
			}
		}

		.sticky {
			position: sticky;
			inset: 0 0 0 auto;
			height: 100lvh;
		}

		.links {
			display: grid;
			overflow-x: clip;

			ul {
				padding-inline: 1em;
			}
		}

		.profile {
			padding: 1em;
			width: 250px;

			> img {
				width: 100%;
				margin-inline: auto;
				aspect-ratio: 1;
				object-fit: cover;
				background: lightblue;
				border-radius: 50%;
			}
		}
	}
</style>
