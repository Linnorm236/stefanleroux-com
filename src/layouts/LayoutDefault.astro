---
import Meta from "../blocks/meta.astro";
import Link from "../blocks/link.astro";

const { pathname } = Astro.url;

const { title, description, image = "favicon.svg" } = Astro.props;
---

<!doctype html>
<html lang="en">
	<Meta title={title} description={description} image={image} />
	<body>
		<label
			for="menu"
			class="icon_application-menu"
			aria-label="menu"
			aria-haspopup="true"
			aria-controls="menu"
		>
			<input type="checkbox" id="menu" />
		</label>
		<nav>
			<div class="sticky">
				<div class="profile">
					<img src="" alt="SR" />
				</div>
				<ul role="menu" aria-labelledby="menubutton">
					<li role="menuitem">
						<Link
							class="icon_view-institution"
							aria-current={pathname === "/" ? "page" : "false"}
							href="/"
							text="Home"
						/>
					</li>
					<li role="menuitem">
						<Link
							class="icon_help-about"
							aria-current={pathname === "/about/" ? "page" : "false"}
							href="/about/"
							text="About"
						/>
					</li>
					<li role="menuitem">
						<Link
							class="icon_document-edit-sign"
							aria-current={pathname === "/blogs/" ? "page" : "false"}
							href="/blogs/"
							text="Blog"
						/>
					</li>
				</ul>
			</div>
		</nav>
		<main>
			<slot />
		</main>
		<footer>test</footer>
	</body>
</html>

<style>
	body {
		--timing: 0.5s;
		--easing: cubic-bezier(0.8, -0.4, 0.5, 1);
		min-block-size: 100svh;
		display: grid;
		grid:
			"nav head" auto
			"nav main" 1fr
			"nav foo" auto / minmax(0, 250px) minmax(0, 1fr);

		& > nav {
			grid-area: nav;
		}

		& > main {
			grid-area: main;
		}

		& > footer {
			grid-area: foo;
		}

		& > :is(label[for="menu"], input[name="menu"]) {
			display: none;
		}

		@media (width <= 900px) {
			& {
				overflow-x: clip;
				grid-template-columns: minmax(0, 0) minmax(0, 1fr);
				transition: grid-template-columns var(--timing) var(--easing);

				nav {
					content-visibility: hidden;
					transition-behavior: allow-discrete;
					transition-delay: 0.5s;
				}

				main,
				footer {
					transition: filter var(--timing) var(--easing);
					width: 100vw;
				}
			}

			&:has(> label[for="menu"] > input#menu:checked) {
				grid-template-columns: minmax(0, 250px) minmax(0, 1fr);
				transition-timing-function: ease-in-out;
				transition-duration: 0.2s;

				nav {
					content-visibility: visible;
					transition-delay: 0s;
				}

				main,
				footer {
					filter: grayscale(50%) brightness(80%);
					transition-timing-function: ease-in-out;
					transition-duration: 0.2s;
				}
			}

			& > label[for="menu"] {
				display: block;
				position: fixed;
				inset: auto 0 0 auto;
				font-family: icons;
				z-index: 1;

				& > input#menu {
					display: block;
					position: fixed;
					width: 0;
					height: 0;
					opacity: 0;
				}

				&::before {
					display: block;
					padding: var(--paddingGap);
					background: oklch(from var(--colorBackground) calc(l + 0.1) c h / 0.8);
					border: solid var(--borderWidth) oklch(from var(--colorBackground) calc(l + 0.2) c h / 1);
					border-radius: var(--borderRadius);
					font-size: 3.5rem;
					line-height: 1;
					translate: -2rem -2rem;
					backdrop-filter: blur(5px);
				}

				&:hover::before,
				&:focus-within::before {
					background: oklch(from var(--colorPrimary) l c h / 0.5);
					border-color: oklch(from var(--colorPrimary) l c h / 1);
				}

				&:has(> input#menu:checked)::before {
					background: oklch(from var(--colorPrimary) l c h / 0.8);
					border-color: oklch(from var(--colorPrimary) l c h / 1);
				}

				&:has(> input#menu:checked):focus::before {
					background: oklch(from var(--colorPrimary) l c h / 0.2);
					border-color: oklch(from var(--colorPrimary) l c h / 0.5);
				}

				&::after {
					display: none;
					content: "";
					position: fixed;
					inset: auto 0 0 auto;
					inline-size: 100vw;
					block-size: 100vh;
					z-index: -1;
				}

				&:has(> input#menu:checked)::after {
					display: block;
				}
			}
		}
	}

	nav {
		position: relative;
		z-index: 1;
		isolation: isolate;

		.sticky {
			position: sticky;
			inset: 0 0 auto auto;
			height: 100lvh;
			overflow: clip auto;
			display: grid;
			place-content: start;
			gap: 2rem;
			padding-block: 2rem;
			background: oklch(from var(--colorBackground) calc(l + 0.045) c h / 0.5);
			box-shadow: inset -0.15rem 0 0 0 oklch(from #fff l c h / 0.1);
			backdrop-filter: blur(3px);
		}

		ul {
			display: grid;
			gap: 1rem;
			padding-inline: 1rem;
		}

		a {
			font-size: 2.5rem;
			inline-size: 100%;
			line-height: 1;

			&[aria-current="page"] {
				background: oklch(from var(--colorPrimary) l c h / 0.5);
				border-color: oklch(from var(--colorPrimary) l c h / 1);
			}
		}

		.profile {
			padding-inline: 1em;
			width: 250px;

			& > img {
				width: 100%;
				margin-inline: auto;
				aspect-ratio: 1;
				object-fit: cover;
				color: oklch(from #02b787 l c h / 1);
				font-size: 10rem;
				background: oklch(from #02b787 l c h / 0.3);
				border-radius: 50%;
				border: solid 0.15rem oklch(from #02b787 l c h / 1);
			}
		}
	}
</style>
