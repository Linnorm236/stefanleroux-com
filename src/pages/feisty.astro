			<li><a href="https://africanartisanconfederation.org/" target="_blank">African Artisan</a></li>
		</ul>
		<h3>Educational</h3>
		<ul role="list" class="clients">
			<li><a href="https://agileculture.co.za/" target="_blank">Agile Culture</a></li>
			<li><a href="https://centreforcoaching.co.za/" target="_blank">Centre for Coaching</a></li>
			<li><a href="https://enbonnesante.co.za/" target="_blank">En Bonne Sante</a></li>
