---
import LayoutCanvas from "../layouts/LayoutCanvas.astro";

import Fox from "../blocks/fox.astro";

const title = "Maxitec";
const description = "My CV for Maxitec application";
const image = "../images/favicon.svg";
---

<LayoutCanvas title={title} description={description} image={image}>
	<article>
		<header>
			<div id="fox">
				<Fox />
			</div>
			<h1>Hello <span style="text-decoration: underline;">FEISTY</span></h1>
		</header>
		<hgroup>
			<h2>I'm Stefan</h2>
			<p>A Front‑end Web Developer turning UI designs into reality.</p>
		</hgroup>
		<h2>About Me</h2>
		<p>
			For the past <strong>4 years</strong> I’ve been the go‑to web‑craftsman at
			<a href="https://inkfish.co.za/" target="_blank">Inkfish Digital Marketing</a>. My day‑to‑day?
		</p>
		<ul role="list" class="clients">
			<li>
				Building & hosting <a href="https://wordpress.org/" target="_blank">WordPress</a> sites and the occasional bespoke
				project from scratch with the <a href="https://astro.build/" target="_blank"> Astro framework</a>.
			</li>
			<li>Translating design files; from Photoshop, Penpot, InDesign, or Figma; into functional websites.</li>
			<li>
				Maintaining 100+ hosting clients, ensuring PHP compatibility, performance optimisations, email deliverability,
				and troubleshooting.
			</li>
			<li>Producing training videos so clients can run their own WooCommerce shops.</li>
			<li>
				Crafting HTML email signatures that render across Outlook, Gmail, Apple Mail, and the rest of the inbox zoo.
			</li>
		</ul>
		<hr />
		<h2>My Technical Toolbox</h2>
		<h3>Frameworks & CMS</h3>
		<ul class="clients" role="list">
			<li>WordPress</li>
			<li>WooCommerce</li>
			<li>Astro</li>
		</ul>
		<h3>Languages</h3>
		<ul class="clients" role="list">
			<li>HTML</li>
			<li>CSS</li>
			<li>SVG</li>
			<li>JavaScript/TypeScript</li>
			<li>PHP</li>
			<li>SQL</li>
		</ul>
		<h3>Design + Video</h3>
		<ul class="clients" role="list">
			<li>Penpot</li>
			<li>Photoshop</li>
			<li>GIMP</li>
			<li>Inkscape</li>
			<li>Krita</li>
			<li>Kdenlive</li>
			<li>OBS Studio</li>
		</ul>
		<hr />
		<h2>Websites I was responible for building</h2>
		<h3>UXI Artisan Group</h3>
		<ul role="list" class="clients">
			<li><a href="https://www.uxi-ad.co.za/" target="_blank">UXI Artisan Group</a></li>
